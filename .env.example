# ==========================================
# Manga Cleaner — Environment Variables
# ==========================================
# انسخ هذا الملف باسم .env وحط القيم الحقيقية

# Telegram Bot (من @BotFather)
TELEGRAM_BOT_TOKEN=ضع_التوكن_هنا

# Telegram API (من my.telegram.org)
TELEGRAM_API_ID=ضع_الـ_ID_هنا
TELEGRAM_API_HASH=ضع_الـ_Hash_هنا

# Redis (لا تغيّره)
REDIS_URL=redis://redis:6379/0

# IOPaint (لا تغيّره)
IOPAINT_URL=http://iopaint:8080

# API URL للبوت (لا تغيّره)
MANGA_API_URL=http://api:8000
